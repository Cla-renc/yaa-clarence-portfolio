# ================================
# YAA CLARENCE PORTFOLIO - Backend Configuration
# ================================
# Copy this file to .env and fill in your actual values

# ===== ENVIRONMENT =====
NODE_ENV=development
PORT=5000

# ===== DATABASE =====
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/yaa_clarence_portfolio?retryWrites=true&w=majority

# ===== CLIENT URL (CORS) =====
CLIENT_URL=http://localhost:5173

# ===== EMAIL SERVICE =====
# For development (MailHog or similar)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# For production (Gmail, SendGrid, etc.)
EMAIL_SERVICE=gmail
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password
EMAIL_FROM=noreply@yaaclarence.com
ADMIN_EMAIL=admin@yaaclarence.com

# Send emails in development (true/false)
SEND_EMAILS=false

# ===== AUTHENTICATION =====
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
BCRYPT_ROUNDS=12

# ===== RATE LIMITING =====
# Redis (optional, for production rate limiting)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== IMAGE UPLOAD =====
# Cloudinary (optional, for image storage)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===== SOCIAL MEDIA INTEGRATION =====
FACEBOOK_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=

# ===== ANALYTICS =====
# Google Analytics
GOOGLE_ANALYTICS_ID=

# Plausible Analytics (privacy-friendly alternative)
PLAUSIBLE_DOMAIN=yaaclarence.com

# ===== LOGGING =====
LOG_LEVEL=info
LOG_FORMAT=json

# ===== SECURITY =====
# CORS headers
ALLOWED_ORIGINS=http://localhost:5173,https://yaaclarence.com,https://www.yaaclarence.com

# Content Security Policy
CSP_ENABLED=true

# HTTPS only
HTTPS_ONLY=false

# ===== THIRD-PARTY INTEGRATIONS =====
# Sentry (error tracking)
SENTRY_DSN=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=
AWS_REGION=us-east-1
