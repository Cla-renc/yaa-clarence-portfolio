# ================================
# YAA CLARENCE PORTFOLIO - Frontend Configuration
# ================================
# Copy this file to .env.local and fill in your actual values

# ===== API CONFIGURATION =====
VITE_API_URL=http://localhost:5000/api
VITE_API_TIMEOUT=10000

# ===== ANALYTICS =====
# Google Analytics
VITE_GOOGLE_ANALYTICS_ID=

# Plausible Analytics (privacy-friendly alternative)
VITE_PLAUSIBLE_DOMAIN=

# ===== SOCIAL MEDIA LINKS =====
VITE_FACEBOOK_URL=https://facebook.com/yaaclarence
VITE_TIKTOK_URL=https://tiktok.com/@yaaclarence
VITE_TWITTER_URL=https://twitter.com/yaaclarence
VITE_LINKEDIN_URL=https://linkedin.com/in/yaaclarence
VITE_GITHUB_URL=https://github.com/yaaclarence

# ===== SITE CONFIGURATION =====
VITE_SITE_URL=http://localhost:5173
VITE_SITE_TITLE=Yaa Clarence | Discipline. Wisdom. Purpose.
VITE_SITE_DESCRIPTION=Explore the portfolio of Yaa Clarence - IT student, author, and creator of the Bruce Lee Discipline Diaries brand.

# ===== IMAGE OPTIMIZATION =====
VITE_ENABLE_IMAGE_OPTIMIZATION=true
VITE_IMAGE_QUALITY=80

# ===== PERFORMANCE =====
VITE_ENABLE_LAZY_LOADING=true
VITE_ENABLE_CODE_SPLITTING=true
VITE_ENABLE_COMPRESSION=true

# ===== ENVIRONMENT =====
VITE_ENV=development
